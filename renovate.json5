{
  extends: ["github>reqstool/.github//.github/renovate.json5"],

  customManagers: [
    {
      // Track engines.vscode as a dependency on @types/vscode so both are bumped in the same PR.
      customType: "regex",
      fileMatch: ["^package\\.json$"],
      matchStrings: ['"vscode":\\s*"\\^(?<currentValue>[\\d.]+)"'],
      depNameTemplate: "@types/vscode",
      datasourceTemplate: "npm",
    },
    {
      // Track reqstoolVersion against the PyPI reqstool package.
      customType: "regex",
      fileMatch: ["^package\\.json$"],
      matchStrings: ['"reqstoolVersion":\\s*"(?<currentValue>[\\d.]+)"'],
      depNameTemplate: "reqstool",
      datasourceTemplate: "pypi",
    },
    {
      // Keep the minimum version note in README in sync with the bundled reqstool version.
      customType: "regex",
      fileMatch: ["^README\\.md$"],
      matchStrings: ["reqstool (?<currentValue>[\\d.]+) or later"],
      depNameTemplate: "reqstool",
      datasourceTemplate: "pypi",
    },
  ],

  packageRules: [
    {
      matchDepNames: ["@types/vscode"],
      groupName: "vscode engine",
    },
    {
      matchDepNames: ["reqstool"],
      groupName: "reqstool",
    },
  ],
}
